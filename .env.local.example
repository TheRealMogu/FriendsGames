# Copia questo file in `.env.local` e compila i valori dal tuo progetto Supabase.
# (Settings -> API)

# URL del progetto e chiave anon: sicure nel bundle client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chiave service_role: SEGRETA. Solo lato server (API Route).
# Non deve mai finire nel bundle client.
SUPABASE_SERVICE_ROLE_KEY=
